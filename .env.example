# Copy file này thành .env và điền giá trị (không commit .env lên git)

# MongoDB (bắt buộc khi deploy – dùng MongoDB Atlas hoặc host có sẵn)
MONGO_URI=mongodb+srv://quanhk1402_db_user:minhquan1402@cluster0.hvmygw5.mongodb.net/?appName=Cluster0
# Hoặc Atlas: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/carRental?retryWrites=true&w=majority

# Port (nhiều host tự gán, không cần set)
PORT=3000

# JWT (nên đổi secret khi deploy)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES=7d

# Chạy production (server lắng nghe 0.0.0.0)
NODE_ENV=production
