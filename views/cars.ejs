<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách xe – CarRental</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg: #0f172a;
            --surface: rgba(30, 41, 59, 0.7);
            --surface-hover: rgba(30, 41, 59, 0.9);
            --border: rgba(255, 255, 255, 0.1);
            --border-focus: rgba(249, 115, 22, 0.5);
            --text-heading: #f8fafc;
            --text-body: #cbd5e1;
            --muted: #94a3b8;
            --accent: #f97316;
            --accent-hover: #ea580c;
            --accent-soft: rgba(249, 115, 22, 0.15);
            --success: #10b981;
            --success-bg: rgba(16, 185, 129, 0.15);
            --warn: #eab308;
            --warn-bg: rgba(234, 179, 8, 0.15);
            --danger: #ef4444;
            --danger-bg: rgba(239, 68, 68, 0.15);
            --radius: 16px;
            --shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
            --glass-blur: blur(12px);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            transition: background-color 0.3s, border-color 0.3s, color 0.3s;
        }

        body {
            font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
            background: var(--bg);
            background-image:
                radial-gradient(at 0% 0%, rgba(249, 115, 22, 0.1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(56, 189, 248, 0.1) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text-body);
            min-height: 100vh;
            line-height: 1.6;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .bar {
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border-bottom: 1px solid var(--border);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .brand-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: linear-gradient(135deg, #f97316, #ea580c);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: white;
            font-weight: 800;
            box-shadow: 0 4px 12px rgba(249, 115, 22, 0.4);
        }

        .brand-text {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: var(--text-heading);
        }

        .brand-text span {
            color: var(--accent);
            font-weight: 500;
        }

        .nav {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav a {
            padding: 10px 18px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-body);
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

        .nav a::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--accent-soft);
            border-radius: 12px;
            z-index: -1;
            transform: scale(0.8);
            opacity: 0;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s;
        }

        .nav a:hover {
            color: var(--accent);
        }

        .nav a:hover::before {
            transform: scale(1);
            opacity: 1;
        }

        .nav a.active {
            color: var(--accent);
            background: var(--accent-soft);
        }

        .main {
            max-width: 1000px;
            margin: 0 auto;
            padding: 40px 24px 80px;
            animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page-head {
            margin-bottom: 32px;
        }

        .page-head h1 {
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
            color: var(--text-heading);
            background: linear-gradient(135deg, #fff, #cbd5e1);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .table-wrap {
            background: var(--surface);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-bottom: 32px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 15px;
        }

        th,
        td {
            padding: 16px 24px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        th {
            font-weight: 600;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--muted);
            background: rgba(15, 23, 42, 0.4);
        }

        tr:last-child td {
            border-bottom: none;
        }

        tbody tr {
            transition: background-color 0.2s;
        }

        tbody tr:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        td strong {
            color: var(--text-heading);
            font-weight: 600;
        }

        .status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
        }

        .status-available {
            background: var(--success-bg);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .status-rented {
            background: var(--warn-bg);
            color: var(--warn);
            border: 1px solid rgba(234, 179, 8, 0.2);
        }

        .status-maintenance {
            background: var(--danger-bg);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .empty {
            text-align: center;
            padding: 64px 24px;
            color: var(--muted);
        }

        .empty strong {
            color: var(--text-heading);
            display: block;
            margin-bottom: 8px;
            font-size: 18px;
        }

        .form-card {
            background: var(--surface);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 32px;
            margin-bottom: 32px;
        }

        .form-card h2 {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 24px;
            color: var(--text-heading);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 20px;
            align-items: end;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group label {
            font-size: 13px;
            font-weight: 600;
            color: var(--muted);
        }

        .form-group input,
        .form-group select {
            padding: 12px 16px;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border);
            border-radius: 12px;
            font-size: 15px;
            color: var(--text-heading);
            outline: none;
            font-family: inherit;
        }

        .form-group select option {
            background: #1e293b;
            color: #f8fafc;
        }

        .form-group input:focus,
        .form-group select:focus {
            border-color: var(--border-focus);
            box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.15);
            background: rgba(15, 23, 42, 0.8);
        }

        .btn {
            padding: 12px 20px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            font-family: inherit;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
            height: 48px;
            /* Match input height */
        }

        .btn-primary {
            background: linear-gradient(135deg, #f97316, #ea580c);
            color: white;
            box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(249, 115, 22, 0.4);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .msg {
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 14px;
            margin-top: 16px;
            display: none;
        }

        .msg:not(:empty) {
            display: block;
            animation: fadeIn 0.3s;
        }

        .msg.success {
            background: var(--success-bg);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .msg.error {
            background: var(--danger-bg);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.2);
        }
    </style>
</head>

<body>
    <header class="bar">
        <div class="brand">
            <div class="brand-icon">CR</div>
            <div class="brand-text">CarRental <span>· Thuê xe</span></div>
        </div>
        <nav class="nav">
            <a href="/">Trang chủ</a>
            <a href="/cars" class="active">Xe</a>
            <a href="/bookings">Đặt xe</a>
            <a href="/login">Đăng nhập</a>
        </nav>
    </header>

    <main class="main">
        <div class="page-head">
            <h1>Danh sách xe</h1>

        </div>

        <div class="form-card">
            <h2>➕ Thêm xe mới</h2>
            <form id="addCarForm">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Biển số *</label>
                        <input type="text" name="carNumber" placeholder="VD: 51A-12345" required>
                    </div>
                    <div class="form-group">
                        <label>Số chỗ *</label>
                        <input type="number" name="capacity" min="1" placeholder="4" required>
                    </div>
                    <div class="form-group">
                        <label>Trạng thái</label>
                        <select name="status">
                            <option value="available">available</option>
                            <option value="rented">rented</option>
                            <option value="maintenance">maintenance</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Giá/ngày (VND) *</label>
                        <input type="number" name="pricePerDay" min="0" placeholder="500000" required>
                    </div>
                    <div class="form-group">
                        <label>Tiện ích (cách nhau bằng dấu phẩy)</label>
                        <input type="text" name="features" placeholder="Điều hòa, GPS, Bluetooth">
                    </div>
                    <div class="form-group">
                        <label>&nbsp;</label>
                        <button type="submit" class="btn btn-primary">Thêm xe mới </button>
                    </div>
                </div>
                <div id="carMsg"></div>
            </form>
        </div>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Biển số</th>
                        <th>Số chỗ</th>
                        <th>Trạng thái</th>
                        <th>Giá/ngày</th>
                        <th>Tiện ích</th>
                    </tr>
                </thead>
                <tbody id="carsTable">
                    <tr>
                        <td colspan="5" class="empty">
                            <strong>Đang tải...</strong>
                            Đang gọi /api/cars
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>

    <script>
        function getAuthHeaders() {
            const token = localStorage.getItem('carRental_token');
            const h = { 'Content-Type': 'application/json' };
            if (token) h['Authorization'] = 'Bearer ' + token;
            return h;
        }
        function loadCars() {
            fetch('/api/cars')
                .then(r => r.json())
                .then(cars => {
                    const tbody = document.getElementById('carsTable');
                    if (!Array.isArray(cars) || cars.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" class="empty"><strong>Chưa có xe.</strong> Dùng form trên để thêm xe.</td></tr>';
                        return;
                    }
                    tbody.innerHTML = cars.map(car => `
                        <tr>
                            <td><strong>${car.carNumber}</strong></td>
                            <td>${car.capacity}</td>
                            <td><span class="status status-${car.status || 'available'}">${car.status}</span></td>
                            <td>${Number(car.pricePerDay || 0).toLocaleString('vi-VN')} VND</td>
                            <td>${Array.isArray(car.features) && car.features.length ? car.features.join(', ') : '—'}</td>
                        </tr>
                    `).join('');
                })
                .catch(() => {
                    document.getElementById('carsTable').innerHTML = '<tr><td colspan="5" class="empty"><strong>Lỗi tải dữ liệu.</strong> Kiểm tra server và MongoDB.</td></tr>';
                });
        }

        loadCars();

        document.getElementById('addCarForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const msgEl = document.getElementById('carMsg');
            const fd = new FormData(this);
            const featuresStr = (fd.get('features') || '').trim();
            const features = featuresStr ? featuresStr.split(',').map(s => s.trim()).filter(Boolean) : [];
            const body = {
                carNumber: fd.get('carNumber').trim(),
                capacity: parseInt(fd.get('capacity'), 10),
                status: fd.get('status'),
                pricePerDay: parseInt(fd.get('pricePerDay'), 10),
                features: features
            };

            fetch('/api/cars', {
                method: 'POST',
                headers: getAuthHeaders(),
                body: JSON.stringify(body)
            })
                .then(r => {
                    if (r.status === 401) {
                        if (confirm('Bạn cần đăng nhập để thêm xe. Chuyển đến trang đăng nhập?')) window.location.href = '/login';
                        return null;
                    }
                    return r.json();
                })
                .then(data => {
                    if (!data) return;
                    if (data.message && data.message.includes('already exists')) {
                        msgEl.className = 'msg error';
                        msgEl.textContent = 'Biển số này đã tồn tại.';
                        return;
                    }
                    if (data.message && data.message.includes('token')) {
                        msgEl.className = 'msg error';
                        msgEl.textContent = data.message + ' <a href="/login">Đăng nhập</a>';
                        return;
                    }
                    msgEl.className = 'msg success';
                    msgEl.textContent = 'Thêm xe thành công';
                    this.reset();
                    loadCars();
                })
                .catch(() => {
                    msgEl.className = 'msg error';
                    msgEl.textContent = 'Lỗi gửi dữ liệu.';
                });
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const userStr = localStorage.getItem('carRental_user');
            if (userStr) {
                try {
                    const user = JSON.parse(userStr);
                    const authLinks = document.querySelectorAll('.nav a[href="/login"]');
                    authLinks.forEach(link => {
                        const profileDiv = document.createElement('div');
                        profileDiv.style.display = 'flex';
                        profileDiv.style.alignItems = 'center';
                        profileDiv.style.gap = '12px';
                        profileDiv.style.marginLeft = '8px';
                        profileDiv.innerHTML = `
                            <span style="font-size: 14px; font-weight: 600; color: var(--text-heading); background: var(--surface-hover, rgba(30, 41, 59, 0.9)); padding: 6px 12px; border-radius: 99px; border: 1px solid var(--border, rgba(255,255,255,0.1));">👋 ${user.name || user.email.split('@')[0]}</span>
                            <button onclick="logout()" style="padding: 6px 12px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: 1px solid rgba(239, 68, 68, 0.3); background: rgba(239, 68, 68, 0.15); color: #ef4444; transition: all 0.3s;">Đăng xuất</button>
                        `;
                        link.replaceWith(profileDiv);
                    });
                } catch (e) {}
            }
        });

        function logout() {
            localStorage.removeItem('carRental_token');
            localStorage.removeItem('carRental_user');
            window.location.reload();
        }
    </script>
</body>

</html>